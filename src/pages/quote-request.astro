---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComplianceBlock from '../components/ComplianceBlock.astro';

// TODO (payments): When a high-risk processor is selected (NMI / Authorize.net / crypto checkout),
// replace the quote-only flow below with a checkout call after the quote is approved by Longhorn.
---
<BaseLayout
  title="Request a Quote"
  description="Submit a quote request for items in your Longhorn Supply & Provision quote list. Pricing and payment instructions returned by email."
  noindex={true}
>
  <section class="container-rugged py-12 lg:py-16">
    <p class="font-display uppercase tracking-[0.3em] text-copper text-xs mb-1">Step 1 of 1</p>
    <h1 class="text-ink">Request a Quote</h1>
    <p class="mt-3 text-charcoal/80 max-w-2xl">
      Review the items in your quote list and submit your details. We'll respond by email with pricing, lot availability, and payment instructions. <strong>No payment is collected on this site.</strong>
    </p>

    <div class="mt-10 grid lg:grid-cols-5 gap-8">
      <!-- Quote items list -->
      <div class="lg:col-span-2">
        <div class="border-2 border-charcoal/20 bg-cream">
          <div class="bg-ink text-cream px-4 py-3 flex items-center justify-between">
            <h2 class="font-display uppercase tracking-wide text-base text-cream">Your Quote List</h2>
            <button
              type="button"
              data-clear-list
              class="text-xs uppercase tracking-wider font-display text-cream/70 hover:text-cream"
            >
              Clear
            </button>
          </div>

          <ul id="quote-items" class="divide-y divide-charcoal/15"></ul>

          <div id="empty-list" hidden class="p-6 text-center text-sm text-charcoal/70">
            Your quote list is empty.<br/>
            <a href="/shop" class="text-copper underline">Browse the catalog</a> to add products.
          </div>

          <div class="px-4 py-3 border-t-2 border-charcoal/15 bg-cream/60 text-xs text-charcoal/60">
            Quote-only. Pricing returned by email.
          </div>
        </div>

        <div class="mt-6">
          <ComplianceBlock variant="full" />
        </div>
      </div>

      <!-- Form -->
      <div class="lg:col-span-3">
        <!--
          Static, build-time form for Netlify field detection. The visible form below
          mirrors these names; the build crawler indexes this version. Hidden from view.
        -->
        <form name="quote-request" data-netlify="true" netlify-honeypot="bot-field" hidden>
          <input type="text" name="name" />
          <input type="email" name="email" />
          <input type="tel" name="phone" />
          <input type="text" name="institution" />
          <input type="text" name="shipping_zip" />
          <textarea name="notes"></textarea>
          <input type="text" name="quote_items" />
          <input type="text" name="research_use_only" />
          <input type="text" name="bot-field" />
        </form>

        <form
          id="quote-form"
          name="quote-request"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/quote-request/thanks"
          class="border-2 border-charcoal/20 bg-cream p-6 sm:p-8 space-y-5"
        >
          <input type="hidden" name="form-name" value="quote-request" />
          <input type="hidden" name="quote_items" id="quote-items-input" value="" />
          <p hidden>
            <label>Don't fill this out if you're human: <input name="bot-field" /></label>
          </p>

          <div class="grid sm:grid-cols-2 gap-4">
            <label class="block">
              <span class="font-display uppercase tracking-wider text-xs text-charcoal/70">Name</span>
              <input
                type="text"
                name="name"
                required
                autocomplete="name"
                class="mt-1 block w-full border-2 border-charcoal/20 bg-cream px-3 py-2 focus:outline-none focus:border-copper"
              />
            </label>
            <label class="block">
              <span class="font-display uppercase tracking-wider text-xs text-charcoal/70">Business / Institutional Email</span>
              <input
                type="email"
                name="email"
                required
                autocomplete="email"
                class="mt-1 block w-full border-2 border-charcoal/20 bg-cream px-3 py-2 focus:outline-none focus:border-copper"
              />
            </label>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <label class="block">
              <span class="font-display uppercase tracking-wider text-xs text-charcoal/70">Phone</span>
              <input
                type="tel"
                name="phone"
                autocomplete="tel"
                class="mt-1 block w-full border-2 border-charcoal/20 bg-cream px-3 py-2 focus:outline-none focus:border-copper"
              />
            </label>
            <label class="block">
              <span class="font-display uppercase tracking-wider text-xs text-charcoal/70">Shipping ZIP</span>
              <input
                type="text"
                name="shipping_zip"
                inputmode="numeric"
                pattern="[0-9]{5}(-[0-9]{4})?"
                required
                autocomplete="postal-code"
                class="mt-1 block w-full border-2 border-charcoal/20 bg-cream px-3 py-2 focus:outline-none focus:border-copper"
              />
            </label>
          </div>

          <label class="block">
            <span class="font-display uppercase tracking-wider text-xs text-charcoal/70">Institution / Lab</span>
            <input
              type="text"
              name="institution"
              class="mt-1 block w-full border-2 border-charcoal/20 bg-cream px-3 py-2 focus:outline-none focus:border-copper"
            />
          </label>

          <label class="block">
            <span class="font-display uppercase tracking-wider text-xs text-charcoal/70">Notes (optional)</span>
            <textarea
              name="notes"
              rows="4"
              placeholder="Quantities, lot preferences, target ship date, custom requests…"
              class="mt-1 block w-full border-2 border-charcoal/20 bg-cream px-3 py-2 focus:outline-none focus:border-copper resize-y"
            ></textarea>
          </label>

          <label class="flex items-start gap-3 text-sm">
            <input type="checkbox" name="research_use_only" value="confirmed" required class="mt-1 h-4 w-4 accent-copper" />
            <span>
              I confirm I am a qualified researcher (21+) and that all materials I purchase from Longhorn Supply &amp; Provision are for <strong>laboratory and research use only</strong>, not for human or animal consumption, and that I have read and agree to the <a href="/terms" class="text-copper underline">Terms of Service</a>.
            </span>
          </label>

          <button type="submit" id="submit-btn" class="btn-primary w-full sm:w-auto">Submit Quote Request</button>

          <p id="form-error" hidden class="text-sm text-red-700 font-medium" role="alert">
            Please add at least one product to your quote list before submitting.
          </p>
          <p class="text-xs text-charcoal/60">
            By submitting, you authorize Longhorn Supply &amp; Provision to contact you regarding this request.
          </p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  type Item = { sku: string; name: string; size: string; category: string; qty: number };
  const STORAGE_KEY = 'lsp:quote-list:v1';

  const listEl = document.getElementById('quote-items') as HTMLUListElement | null;
  const emptyEl = document.getElementById('empty-list');
  const itemsInput = document.getElementById('quote-items-input') as HTMLInputElement | null;
  const form = document.getElementById('quote-form') as HTMLFormElement | null;
  const errorEl = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  function read(): Item[] {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      const items = raw ? JSON.parse(raw) : [];
      return Array.isArray(items) ? items : [];
    } catch {
      return [];
    }
  }
  function write(items: Item[]) {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
      window.dispatchEvent(new CustomEvent('lsp:quote-list:change'));
    } catch {
      /* ignore */
    }
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => (
      { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string
    ));
  }

  function render() {
    const items = read();
    if (!listEl || !emptyEl || !itemsInput) return;

    if (items.length === 0) {
      listEl.innerHTML = '';
      emptyEl.hidden = false;
      itemsInput.value = '';
      if (submitBtn) submitBtn.disabled = true;
      return;
    }

    emptyEl.hidden = true;
    if (submitBtn) submitBtn.disabled = false;

    listEl.innerHTML = items.map((item, i) => `
      <li class="p-4 flex items-start justify-between gap-3">
        <div class="min-w-0 flex-1">
          <p class="font-display uppercase text-sm text-ink truncate">${escapeHtml(item.name)}</p>
          <p class="text-xs text-charcoal/70 mt-0.5">${escapeHtml(item.size)} · <span class="font-mono">${escapeHtml(item.sku)}</span></p>
        </div>
        <div class="flex items-center gap-2">
          <button type="button" data-qty-dec="${i}" class="h-7 w-7 border border-charcoal/30 text-charcoal hover:border-charcoal" aria-label="Decrease quantity">−</button>
          <span class="w-6 text-center font-display text-sm" aria-label="Quantity">${item.qty}</span>
          <button type="button" data-qty-inc="${i}" class="h-7 w-7 border border-charcoal/30 text-charcoal hover:border-charcoal" aria-label="Increase quantity">+</button>
          <button type="button" data-remove="${i}" class="ml-1 text-charcoal/50 hover:text-red-700" aria-label="Remove">×</button>
        </div>
      </li>
    `).join('');

    // Serialize for Netlify Forms — both human-readable and structured.
    const serialized = items.map(
      (i) => `${i.qty}× ${i.name} (${i.size}) [SKU: ${i.sku}]`,
    ).join('\n');
    itemsInput.value = serialized + '\n\n--- JSON ---\n' + JSON.stringify(items);
  }

  listEl?.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    const items = read();
    if (t.dataset.qtyInc !== undefined) {
      const idx = Number(t.dataset.qtyInc);
      if (items[idx]) items[idx].qty += 1;
      write(items);
      render();
    } else if (t.dataset.qtyDec !== undefined) {
      const idx = Number(t.dataset.qtyDec);
      if (items[idx]) items[idx].qty = Math.max(1, items[idx].qty - 1);
      write(items);
      render();
    } else if (t.dataset.remove !== undefined) {
      const idx = Number(t.dataset.remove);
      items.splice(idx, 1);
      write(items);
      render();
    }
  });

  document.querySelector<HTMLButtonElement>('[data-clear-list]')?.addEventListener('click', () => {
    if (!confirm('Remove all items from your quote list?')) return;
    write([]);
    render();
  });

  form?.addEventListener('submit', (e) => {
    const items = read();
    if (items.length === 0) {
      e.preventDefault();
      errorEl?.removeAttribute('hidden');
      return;
    }
    errorEl?.setAttribute('hidden', '');
    // Clear the quote list after successful submit handoff.
    // We can't reliably know success on submit, but Netlify redirects to /quote-request/thanks
    // and the thanks page will clear localStorage.
  });

  window.addEventListener('storage', render);
  window.addEventListener('lsp:quote-list:change', render as EventListener);
  render();
</script>
