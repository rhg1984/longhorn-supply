---
const navItems = [
  { href: '/shop', label: 'Shop' },
  { href: '/quality', label: 'Quality & COAs' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---
<header class="bg-cream border-b-2 border-charcoal/15 sticky top-0 z-30 backdrop-blur supports-[backdrop-filter]:bg-cream/90">
  <div class="container-rugged flex items-center justify-between gap-4 py-4">
    <a href="/" class="flex items-center gap-3 no-underline group" aria-label="Longhorn Supply & Provision — home">
      <img
        src="/logo.png"
        alt="Longhorn Supply & Provision logo"
        width="56"
        height="56"
        class="h-12 w-12 sm:h-14 sm:w-14 transition-transform group-hover:scale-105"
        loading="eager"
        decoding="async"
      />
      <span class="hidden sm:flex flex-col leading-tight">
        <span class="font-display text-lg sm:text-xl font-semibold tracking-tight text-ink uppercase">Longhorn Supply</span>
        <span class="font-display text-[0.65rem] sm:text-xs tracking-[0.25em] text-copper uppercase">&amp; Provision</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Primary">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'px-3 py-2 font-display text-sm uppercase tracking-wide no-underline border-b-2 transition-colors',
            isActive(item.href)
              ? 'border-copper text-ink'
              : 'border-transparent text-charcoal hover:text-ink hover:border-charcoal/30',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="/quote-request"
        class="btn-outline px-3 py-2 text-xs sm:text-sm relative"
        aria-label="View quote list"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" class="h-4 w-4" aria-hidden="true">
          <path d="M4 4h2l2 12h10l2-8H7" />
          <circle cx="9" cy="20" r="1.5" fill="currentColor" stroke="none" />
          <circle cx="17" cy="20" r="1.5" fill="currentColor" stroke="none" />
        </svg>
        <span class="hidden sm:inline">Quote List</span>
        <span
          data-quote-count
          class="ml-1 inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1 bg-copper text-cream text-[0.65rem] font-display font-semibold leading-none"
        >0</span>
      </a>

      <button
        type="button"
        class="md:hidden btn-ghost p-2"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
        data-mobile-toggle
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" class="h-6 w-6" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" hidden class="md:hidden border-t border-charcoal/15 bg-cream" aria-label="Mobile">
    <ul class="container-rugged py-2">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block px-2 py-3 font-display text-base uppercase tracking-wide no-underline border-b border-charcoal/10',
              isActive(item.href) ? 'text-copper' : 'text-charcoal hover:text-ink',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  // Mobile nav toggle
  const toggle = document.querySelector<HTMLButtonElement>('[data-mobile-toggle]');
  const mobileNav = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    if (!mobileNav) return;
    const open = mobileNav.hasAttribute('hidden') ? false : true;
    if (open) {
      mobileNav.setAttribute('hidden', '');
      toggle.setAttribute('aria-expanded', 'false');
    } else {
      mobileNav.removeAttribute('hidden');
      toggle.setAttribute('aria-expanded', 'true');
    }
  });

  // Quote-list count badge — reads from localStorage key 'lsp:quote-list:v1'
  function refreshQuoteCount() {
    try {
      const raw = localStorage.getItem('lsp:quote-list:v1');
      const items = raw ? JSON.parse(raw) : [];
      const count = Array.isArray(items)
        ? items.reduce((sum: number, i: { qty?: number }) => sum + (i?.qty || 1), 0)
        : 0;
      document.querySelectorAll<HTMLElement>('[data-quote-count]').forEach((el) => {
        el.textContent = String(count);
      });
    } catch {
      /* ignore */
    }
  }
  refreshQuoteCount();
  window.addEventListener('storage', refreshQuoteCount);
  window.addEventListener('lsp:quote-list:change', refreshQuoteCount as EventListener);
</script>
