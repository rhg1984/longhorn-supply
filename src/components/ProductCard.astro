---
import type { CollectionEntry } from 'astro:content';

interface Props {
  product: CollectionEntry<'products'>;
}
const { product } = Astro.props;
const { name, category, purity, sizes, cas, molecularWeight, inStock } = product.data;
const href = `/shop/${product.data.slug ?? product.id.replace(/\.md$/, '')}`;

const categoryLabel: Record<string, string> = {
  peptides: 'Peptide',
  'amino-acids': 'Amino Acid',
  supplies: 'Supply',
  glassware: 'Glassware',
};
---
<article class="card-rugged group flex flex-col hover:border-charcoal/40">
  <a href={href} class="block no-underline flex-1 flex flex-col">
    <div class="aspect-[5/3] bg-paper-grain bg-ink/5 border-b-2 border-charcoal/15 flex items-center justify-center overflow-hidden">
      <img
        src="/logo.png"
        alt=""
        width="120"
        height="120"
        loading="lazy"
        decoding="async"
        class="h-20 w-20 opacity-30 transition-opacity group-hover:opacity-50"
      />
    </div>
    <div class="p-5 flex-1 flex flex-col">
      <div class="flex items-center justify-between gap-2 mb-2">
        <span class="badge">{categoryLabel[category]}</span>
        {inStock ? (
          <span class="text-xs uppercase tracking-wider font-display text-copper">In Stock</span>
        ) : (
          <span class="text-xs uppercase tracking-wider font-display text-charcoal/50">Backordered</span>
        )}
      </div>

      <h3 class="text-xl text-ink mb-1 group-hover:text-copper transition-colors">{name}</h3>

      <dl class="text-xs text-charcoal/70 mb-3 space-y-0.5">
        {cas && (
          <div class="flex gap-2">
            <dt class="font-display uppercase tracking-wider">CAS:</dt>
            <dd>{cas}</dd>
          </div>
        )}
        {molecularWeight && (
          <div class="flex gap-2">
            <dt class="font-display uppercase tracking-wider">MW:</dt>
            <dd>{molecularWeight} g/mol</dd>
          </div>
        )}
        <div class="flex gap-2">
          <dt class="font-display uppercase tracking-wider">Purity:</dt>
          <dd>{purity}</dd>
        </div>
      </dl>

      <div class="mt-auto pt-3 border-t border-charcoal/10 flex items-center justify-between text-sm">
        <span class="text-charcoal/70">
          {sizes.length} size{sizes.length === 1 ? '' : 's'}
        </span>
        <span class="font-display uppercase tracking-wide text-copper group-hover:translate-x-1 transition-transform">
          View →
        </span>
      </div>
    </div>
  </a>
</article>
